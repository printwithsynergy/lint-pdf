# Source this file (or a copy of it) before running scripts/desktop-release.sh.
# Copy:   cp .env.desktop-release.example .env.desktop-release
# Fill in the blanks below, then: source .env.desktop-release
# DO NOT COMMIT the filled-in copy — .env.desktop-release is gitignored.

# ── Cloudflare R2 (where desktop installers are uploaded) ─────────────
# Dashboard → R2 → Manage API tokens → Create API token with
# permission "Object Read & Write" scoped to the `lintpdf-uploads` bucket.
export R2_ENDPOINT_URL="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
export R2_BUCKET_NAME="lintpdf-uploads"
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
export AWS_DEFAULT_REGION="auto"

# ── Tauri updater signing key (required) ──────────────────────────────
# Contents of ~/.tauri/lintpdf-updater.key — store the private key and
# its password in 1Password under "LintPDF / Tauri Updater".
# NB: TAURI_SIGNING_PRIVATE_KEY must hold the **contents** of the file,
# not the path. You can do: export TAURI_SIGNING_PRIVATE_KEY="$(cat ~/.tauri/lintpdf-updater.key)"
export TAURI_SIGNING_PRIVATE_KEY=""
export TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""

# ── Optional: macOS notarisation ──────────────────────────────────────
# Without these, the local macOS .dmg will still build but Gatekeeper
# will warn users the first time they launch it. Credentials live in
# 1Password under "LintPDF / Apple Developer".
# export APPLE_SIGNING_IDENTITY="Developer ID Application: LintPDF (XXXXXXXXXX)"
# export APPLE_ID="ops@lintpdf.com"
# export APPLE_TEAM_ID="XXXXXXXXXX"
# export APPLE_PASSWORD=""   # app-specific password, not your Apple ID password
