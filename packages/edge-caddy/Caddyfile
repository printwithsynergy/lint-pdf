# LintPDF edge — Caddy with on-demand TLS
#
# Customers' OWN domains (e.g. ``reports.acme.com``) CNAME here. Caddy
# requests a Let's Encrypt cert on first request, terminates TLS, and
# path-routes to Railway's reports + app backends. Railway never sees
# the customer hostname -- we proxy with ``Host: reports.lintpdf.com``
# or ``Host: app.lintpdf.com``, which Railway already has registered.
#
# Abuse guard: on_demand_tls only issues certs for hostnames the
# engine recognizes (known tenant / brand-profile domain). The
# ``ask`` endpoint is called by Caddy before each cert issuance.

{
  email ops@lintpdf.com

  # Caddy 2.8+ dropped ``interval`` + ``burst`` from ``on_demand_tls`` --
  # abuse prevention is now purely the ``ask`` endpoint's responsibility.
  # Our ask endpoint hits the engine to verify the hostname is registered
  # on a tenant / brand profile, so unknown hostnames never reach LE.
  on_demand_tls {
    ask http://127.0.0.1:8081/ask
  }

  # If Caddy hits a persistent LE validation failure (transient ACME /
  # engine-ask hiccup, etc.) it records the failed order and won't retry
  # for HOURS by default. That leaves customer hostnames stuck with no
  # cert. 60 s retry backoff is a reasonable middle ground: long enough
  # not to thrash LE, short enough that the next real request after an
  # outage will mint cleanly.
  cert_issuer acme {
    dir https://acme-v02.api.letsencrypt.org/directory
  }
}

# -------- HTTP health check (port 80 published, 8080 internal) --------
:8080 {
  handle /__edge/health {
    respond "ok" 200
  }
  handle {
    respond "lintpdf-edge" 200
  }
}

# -------- Internal ask-proxy (not published; localhost only) --------
# Caddy's ``on_demand_tls.ask`` can only do GET with a query string.
# We forward the GET to the engine's ``/api/v1/internal/on-demand-tls-check``
# with the shared secret header injected from the ``LINTPDF_EDGE_SHARED_SECRET``
# env var (set via fly secrets).
:8081 {
  handle /ask {
    rewrite * /api/v1/internal/on-demand-tls-check?{query}
    reverse_proxy https://api.lintpdf.com {
      header_up Host api.lintpdf.com
      header_up X-Edge-Shared-Secret {$LINTPDF_EDGE_SHARED_SECRET}
      transport http {
        tls
        tls_server_name api.lintpdf.com
      }
    }
  }
}

# -------- TLS on 443 -- match ANY hostname, on-demand cert --------
:443 {
  tls {
    on_demand
  }

  # Static reports + public viewer API -> reports.lintpdf.com
  @reports path /r/* /api/v1/*
  handle @reports {
    reverse_proxy https://reports.lintpdf.com {
      header_up Host reports.lintpdf.com
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      transport http {
        tls
        tls_server_name reports.lintpdf.com
      }
    }
  }

  # Interactive viewer + Next.js assets + dashboard -> app.lintpdf.com
  @app path /view/* /_next/* /dashboard/* /favicon.ico /robots.txt
  handle @app {
    reverse_proxy https://app.lintpdf.com {
      header_up Host app.lintpdf.com
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      transport http {
        tls
        tls_server_name app.lintpdf.com
      }
    }
  }

  # Default -- landing, /login, etc. -> App service
  handle {
    reverse_proxy https://app.lintpdf.com {
      header_up Host app.lintpdf.com
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      transport http {
        tls
        tls_server_name app.lintpdf.com
      }
    }
  }

  log {
    output stdout
    format json
  }
}
