# ─── Database ──────────────────────────────────────────────────
LINTPDF_DATABASE_URL=postgresql://lintpdf:lintpdf@localhost:5432/lintpdf

# ─── Redis ─────────────────────────────────────────────────────
LINTPDF_REDIS_URL=redis://localhost:6379/0

# ─── veraPDF Sidecar ──────────────────────────────────────────
LINTPDF_VERAPDF_URL=http://localhost:8080

# ─── API Server ────────────────────────────────────────────────
LINTPDF_API_HOST=0.0.0.0
LINTPDF_API_PORT=8000
LINTPDF_SECRET_KEY=change-me-in-production

# ─── S3-Compatible Storage (Cloudflare R2) ─────────────────────
LINTPDF_S3_ENDPOINT_URL=
LINTPDF_S3_BUCKET_NAME=lintpdf-uploads
LINTPDF_S3_ACCESS_KEY_ID=
LINTPDF_S3_SECRET_ACCESS_KEY=
LINTPDF_S3_REGION=auto

# CDN tile delivery (optional). When set, the viewer fetches pre-warmed
# tiles directly from the R2 CDN custom domain instead of proxying
# through the engine. Set to the base URL of the R2 custom domain.
# LINTPDF_TILE_CDN_BASE_URL=https://cdn.lintpdf.com

# ─── Email (Resend) ───────────────────────────────────────────
LINTPDF_RESEND_API_KEY=
LINTPDF_EMAIL_FROM_ADDRESS=LintPDF <noreply@thinkneverland.com>

# ─── Upload Limits ────────────────────────────────────────────
LINTPDF_MAX_UPLOAD_SIZE_MB=1024

# ─── Report Hosting ──────────────────────────────────────────
LINTPDF_REPORT_BASE_URL=https://reports.lintpdf.com

# ─── Admin ───────────────────────────────────────────────────
LINTPDF_ADMIN_API_KEY=

# ─── GPU Inference Service (Modal) ───────────────────────────
# Production: https://quincy-codes--lintpdf-inference-serve-app.modal.run
LINTPDF_GPU_INFERENCE_URL=http://localhost:8001

# ─── ClamAV Virus Scanning (REQUIRED) ────────────────────────
# Every upload endpoint fails-closed (HTTP 503) if this is unset or unreachable.
# Local docker-compose provides a `clamav` service — use "clamav:3310" there,
# or "localhost:3310" when running the API outside compose.
LINTPDF_CLAMAV_URL=clamav:3310

# ─── Trial / Try-It Page ─────────────────────────────────────
# Shared secret between the marketing site (/api/try-it) and the engine.
LINTPDF_TRIAL_SECRET=
# Where new-submission notification emails are sent.
LINTPDF_ADMIN_EMAIL=hello@thinkneverland.com
# When true, preflight is auto-queued on submission (admin still sends the report).
# When false (default), the submission sits in PENDING until an admin clicks Run Preflight.
LINTPDF_TRIAL_AUTO_SUBMIT=false
LINTPDF_TRIAL_AUTO_SUBMIT_PROFILE_ID=lintpdf-default

# ─── Bulk-files scaling knobs (session 2, 2026-04-21) ─────────
# Uvicorn worker process count per API container. Default 4.
# Bumped to 8 in production. Each replica × LINTPDF_WORKERS processes.
LINTPDF_WORKERS=8
# Max in-flight async handlers per Uvicorn worker before 503.
# Lower cap = back-pressure kicks in earlier, protecting container RSS.
LINTPDF_CONCURRENCY_PER_WORKER=15
# Size of the asyncio default-executor thread pool. Python default is
# min(32, cpu_count+4) ≈ 6 on 2-vCPU Railway; that saturates under
# concurrent R2 uploads via run_in_executor. Bumped to 32 so /ready
# isn't starved behind upload threads.
LINTPDF_ASYNCIO_EXECUTOR_WORKERS=32
# Set to "1" on the API-Control-Plane service only. Makes the engine
# mount ONLY /ready + /api/v1/status + /api/v1/admin/* + branding/usage/
# profiles/webhooks/edge. Uploads, jobs, reports, viewer, trial, batch,
# AI routers are not mounted. Keeps the operational plane reachable
# even when the main API is saturated by a bulk-files burst.
LINTPDF_CONTROL_PLANE_ONLY=

# ─── ClamAV enforcement (session 2) ──────────────────────────
# Default (unset or "0"): uploads fail-open when ClamAV is unreachable
# (documented in CLAUDE.md — the upstream railway-clamav image has
# a build-time config bug). Set to "1" to enforce fail-closed scanning
# — required for SOC2/HIPAA-adjacent compliance. Verify the in-repo
# sidecar at packages/engine/clamav/ is deployed first.
LINTPDF_CLAMAV_REQUIRED=0

# ─── Celery worker concurrency (per-service) ─────────────────
# Main Worker (subscribes to default,priority,ai_heavy)
CELERY_DEFAULT_CONCURRENCY=8
# Dedicated Worker-AI (subscribes only to ai_heavy, bounded by Modal)
CELERY_AI_CONCURRENCY=8
# Worker-Webhooks (subscribes to webhooks)
CELERY_WEBHOOK_CONCURRENCY=4
# Staged — not yet spun up. Promote when step-11 /metrics show the split is needed.
CELERY_REPORTS_CONCURRENCY=4
CELERY_TILES_CONCURRENCY=2
