# ─── Database ──────────────────────────────────────────────────
GROUNDED_DATABASE_URL=postgresql://grounded:grounded@localhost:5432/grounded

# ─── Redis ─────────────────────────────────────────────────────
GROUNDED_REDIS_URL=redis://localhost:6379/0

# ─── veraPDF Sidecar ──────────────────────────────────────────
GROUNDED_VERAPDF_URL=http://localhost:8080

# ─── API Server ────────────────────────────────────────────────
GROUNDED_API_HOST=0.0.0.0
GROUNDED_API_PORT=8000
GROUNDED_SECRET_KEY=change-me-in-production

# ─── S3-Compatible Storage (Cloudflare R2) ─────────────────────
GROUNDED_S3_ENDPOINT_URL=
GROUNDED_S3_BUCKET_NAME=grounded-uploads
GROUNDED_S3_ACCESS_KEY_ID=
GROUNDED_S3_SECRET_ACCESS_KEY=
GROUNDED_S3_REGION=auto

# ─── Email (Resend) ───────────────────────────────────────────
GROUNDED_RESEND_API_KEY=
GROUNDED_EMAIL_FROM_ADDRESS=Grounded <noreply@thinkneverland.com>

# ─── Upload Limits ────────────────────────────────────────────
GROUNDED_MAX_UPLOAD_SIZE_MB=1024

# ─── Report Hosting ──────────────────────────────────────────
GROUNDED_REPORT_BASE_URL=https://reports.grounded.dev

# ─── Admin ───────────────────────────────────────────────────
GROUNDED_ADMIN_API_KEY=

# ─── GPU Inference Service ───────────────────────────────────
GROUNDED_GPU_INFERENCE_URL=http://localhost:8001
