{
  "name": "GWG 2022 Newspaper (Variant 3)",
  "description": "GWG 2022 process control for newspaper printing. Lower DPI and TAC requirements.",
  "version": "1.0",
  "conformance": "pdfx4",
  "workflow": "CMYK",
  "checks": {
    "enabled": [
      "LPDF_*",
      "PDFX4-*"
    ],
    "disabled": [],
    "severity_overrides": {}
  },
  "thresholds": {
    "min_dpi": 170.0,
    "max_dpi": 400.0,
    "tac_limit": 240.0,
    "min_bleed_mm": 3.0,
    "hairline_threshold": 0.3,
    "small_text_threshold": 6.0,
    "very_small_text_threshold": 5.0,
    "safety_margin_mm": 3.0,
    "max_file_size_mb": 500.0,
    "min_pdf_version": "1.6"
  }
}
