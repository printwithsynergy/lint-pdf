{
  "name": "LintPDF Default",
  "description": "Comprehensive preflight with all engine checks, PDF/X-4 conformance, and AI analysis.",
  "version": "1.3",
  "conformance": "pdfx4",
  "workflow": "CMYK",
  "checks": {
    "enabled": [
      "LPDF_*",
      "PDFX4-*",
      "PDFX1A-*",
      "PDFA-*",
      "AI_*"
    ],
    "disabled": [
      "LPDF_FONT_016",
      "LPDF_FONT_017"
    ],
    "severity_overrides": {}
  },
  "thresholds": {
    "min_dpi": 150.0,
    "max_dpi": 600.0,
    "tac_limit": 300.0,
    "min_bleed_mm": 3.0,
    "hairline_threshold": 0.25,
    "small_text_threshold": 6.0,
    "very_small_text_threshold": 4.0,
    "safety_margin_mm": 3.0,
    "max_file_size_mb": 500.0
  },
  "ai": {
    "enabled": true,
    "categories": [
      "all"
    ],
    "features": []
  }
}
