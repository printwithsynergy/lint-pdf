{
  "name": "LintPDF Advisory Only",
  "description": "Non-blocking profile. All checks run but severity capped at advisory.",
  "version": "1.0",
  "conformance": null,
  "workflow": "auto",
  "checks": {
    "enabled": ["LPDF_*"],
    "disabled": ["PDFX4-*"],
    "severity_overrides": {},
    "max_severity": "advisory"
  },
  "thresholds": {
    "min_dpi": 150.0,
    "max_dpi": 600.0,
    "tac_limit": 300.0,
    "min_bleed_mm": 3.0,
    "hairline_threshold": 0.25,
    "small_text_threshold": 6.0,
    "very_small_text_threshold": 4.0,
    "safety_margin_mm": 3.0,
    "max_file_size_mb": 500.0
  }
}
