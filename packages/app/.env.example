# Database
#
# PRODUCTION (Railway): append pool params to DATABASE_URL so Prisma
# doesn't open more than its fair share of the shared connection budget
# (see "Connection budget" in the root CLAUDE.md). Example:
#   postgresql://...@host:5432/db?connection_limit=15&pool_timeout=20&pgbouncer=false
# DIRECT_URL is only used for `prisma migrate` and should omit the pool
# params so migrations can open a dedicated connection.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lintpdf_app"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/lintpdf_app"

# App
APP_URL="http://localhost:3001"
NODE_ENV="development"

# Auth
MAGIC_LINK_SECRET="change-me-to-a-random-string"
SESSION_SECRET="change-me-to-a-random-string"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@lintpdf.com"

# Redis (rate limiting)
REDIS_URL="redis://localhost:6379"

# Stripe
STRIPE_MODE="standard"
STRIPE_SANDBOX="true"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# LintPDF Engine
LINTPDF_API_URL="http://localhost:8000"
LINTPDF_WEBHOOK_SECRET=""
LINTPDF_API_KEY=""
LINTPDF_ADMIN_API_KEY=""

# MCP Backdoor (dev only — leave empty in production)
MCP_BACKDOOR=""
MCP_SECRET_KEY=""

# Plugin Control (comma-separated list of plugin names to disable)
DISABLED_PLUGINS=""
