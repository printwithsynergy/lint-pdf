    "@thinkneverland/pixie-dust-api-keys": "^1.2.1",
    "@thinkneverland/pixie-dust-auth": "^1.10.0",
    "@thinkneverland/pixie-dust-boilerplate": "^1.2.12",
    "@thinkneverland/pixie-dust-config": "^1.2.10",
    "@thinkneverland/pixie-dust-cookie-consent": "^1.0.10",
    "@thinkneverland/pixie-dust-core": "^1.2.11",
    "@thinkneverland/pixie-dust-dashboard": "^1.18.1",
    "@thinkneverland/pixie-dust-database": "^2.4.0",
    "@thinkneverland/pixie-dust-devtools": "^1.0.12",
    "@thinkneverland/pixie-dust-email": "^1.6.0",
    "@thinkneverland/pixie-dust-fairy-ring": "^1.7.1",
    "@thinkneverland/pixie-dust-stripe-kit": "^1.4.0",
    "@thinkneverland/pixie-dust-theme-default": "^1.2.8",
    "@thinkneverland/pixie-dust-theme-kit": "^1.2.6",
    "@thinkneverland/pixie-dust-ui": "^4.0.13",
    "@thinkneverland/pixie-dust-usage": "^1.1.1",
    "@thinkneverland/pixie-dust-waitlist": "^1.2.1",
    "@thinkneverland/pixie-dust-webhooks": "^1.1.1",
    "@trpc/client": "^11.16.0",
    "@trpc/next": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "fabric": "^6.0.0",
    "lucide-react": "^0.469.0",
    "gray-matter": "^4.0.3",
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-rehype": "^11.1.2",
    "superjson": "^2.2.6",
    "zod": "^3.25.76"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.56.1",
    "@prisma/client": "^7.6.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@thinkneverland/pixie-dust-tsconfig": "^1.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.14",
