// ============================================
// PAGE BUILDER — Pages, Templates, Media
// ============================================

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// A marketing/landing page composed of ordered blocks.
/// Blocks are stored as JSON — the page renderer resolves block types to React components at render time.
model Page {
  id          String     @id @default(cuid())
  tenantId    String?
  slug        String
  title       String
  description String?
  status      PageStatus @default(DRAFT)
  /// Reference to the template this page was created from (null if standalone)
  templateId  String?
  /// Ordered array of PageBlock objects: [{ id, type, variant, props }]
  blocks      Json       @default("[]")
  /// SEO metadata: { title?, description?, ogImage?, ogTitle?, canonical?, noIndex? }
  metadata    Json       @default("{}")
  publishedAt DateTime?
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
  @@index([slug])
}

/// A reusable page template — a pre-built composition of blocks.
/// Built-in templates ship with Pixie Dust; custom templates can be saved from pages.
model PageTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  /// Category for grouping: "saas", "ecommerce", "portfolio", "general"
  category    String   @default("general")
  /// Preview thumbnail URL
  thumbnail   String?
  /// Default block composition: PageBlock[]
  blocks      Json     @default("[]")
  /// Default SEO metadata
  metadata    Json     @default("{}")
  /// Whether this is a built-in template (not deletable)
  isBuiltIn   Boolean  @default(false)
  /// Optional theme ID this template is designed for
  themeId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isBuiltIn])
}

/// A media asset (image, video, document) in the media library.
/// Shared across page builder, content-pilot, and branding.
model MediaAsset {
  id        String   @id @default(cuid())
  tenantId  String?
  /// Original filename
  filename  String
  /// Public URL
  url       String
  /// MIME type (e.g., "image/png", "video/mp4")
  mimeType  String
  /// File size in bytes
  size      Int
  /// Alt text for accessibility
  alt       String?
  /// Folder path for organization (e.g., "/marketing", "/blog")
  folder    String   @default("/")
  /// Image width in pixels (null for non-images)
  width     Int?
  /// Image height in pixels (null for non-images)
  height    Int?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([folder])
  @@index([mimeType])
}
