generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// TENANTS
// ============================================

model Tenant {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  domain         String?      @unique
  engineTenantId String?
  settings       Json         @default("{}")
  status         TenantStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users   TenantUser[]
  invites TenantInvite[]

  @@index([slug])
  @@index([status])
}

enum TenantStatus {
  ACTIVE
  ONBOARDING
  SUSPENDED
  ARCHIVED
}

// ============================================
// USERS
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  avatarUrl    String?
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants TenantUser[]
  sessions Session[]
  magicLinks MagicLink[]
  invites TenantInvite[]

  @@index([email])
}

// ============================================
// TENANT USERS (MEMBERSHIPS)
// ============================================

model TenantUser {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@index([role])
}

enum TenantRole {
  OWNER
  ADMIN
  OPERATOR
  MEMBER
  VIEWER
}

// ============================================
// TENANT INVITES
// ============================================

model TenantInvite {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  role      UserRole  @default(MEMBER)
  token     String    @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [email], references: [email])

  @@index([token])
  @@index([email])
  @@index([expiresAt])
}

// ============================================
// SESSIONS
// ============================================

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  /// When set, the super admin is viewing/acting on behalf of this tenant.
  /// This is NOT true impersonation — the session still belongs to the super admin.
  impersonatingTenantId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  /// Set when this action was performed by a super admin assisting the tenant.
  /// The userId is always the super admin's real ID — this field makes it
  /// explicit in audit queries that the action was on behalf of a customer.
  impersonatedBy String?

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// MAGIC LINKS
// ============================================

model MagicLink {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  pollingToken String?   @unique
  code         String?
  ipAddress    String?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([pollingToken])
  @@index([userId])
  @@index([expiresAt])
  @@index([code])
  @@index([ipAddress])
}

// ============================================
// APP SETTINGS (singleton — id always "singleton")
// ============================================

model AppSettings {
  id                   String   @id @default("singleton")
  brandName            String?
  brandLogoUrl         String?  /// Logo for light mode / default
  brandLogoUrlDark     String?  /// Logo for dark mode (falls back to brandLogoUrl)
  brandTagline         String?
  customCss            String?
  primaryColor         String?  /// Hex e.g. "#1d4ed8" — login buttons, email CTA, accents
  accentColor          String?  /// Hex — accent highlight color (defaults to primaryColor)
  emailButtonColor     String?  /// Hex — email CTA button (falls back to primaryColor)
  loginBgColor         String?  /// Hex — login page background in light mode
  loginCardColor       String?  /// Hex — login card background in light mode
  loginTextColor       String?  /// Hex — login page text in light mode
  loginInputColor      String?  /// Hex — login input background in light mode
  loginRingColor       String?  /// Hex — login focus ring color
  loginBgColorDark     String?  /// Hex — login page background in dark mode
  loginCardColorDark   String?  /// Hex — login card background in dark mode
  loginTextColorDark   String?  /// Hex — login page text in dark mode
  loginInputColorDark  String?  /// Hex — login input background in dark mode
  loginRingColorDark   String?  /// Hex — login focus ring in dark mode
  sidebarBgColor       String?  /// Hex — sidebar background
  sidebarTextColor     String?  /// Hex — sidebar text color
  sidebarAccentColor   String?  /// Hex — sidebar active/hover accent
  faviconUrl           String?  /// Favicon as data URL or path
  loginHeading         String?  /// Custom login heading
  loginSubheading      String?  /// Custom login subheading
  disabledPlugins      String?  /// Comma-separated plugin names to disable
  updatedAt            DateTime @updatedAt
}

// ============================================
// WAITLIST
// ============================================

model WaitlistEntry {
  id         String         @id @default(cuid())
  email      String         @unique
  name       String?
  company    String?
  useCase    String?
  status     WaitlistStatus @default(PENDING)
  promotedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([email])
  @@index([status])
}

enum WaitlistStatus {
  PENDING
  PROMOTED
  DECLINED
}

// ============================================
// ANNOTATIONS
// ============================================

model Annotation {
  id          String   @id @default(cuid())
  jobId       String
  tenantId    String
  pageNum     Int
  authorId    String?
  authorEmail String
  authorName  String?
  fabricJson  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobId, pageNum])
  @@index([tenantId])
}

// ============================================
// REPORT VIEWS
// ============================================

model ReportView {
  id          String   @id @default(cuid())
  jobId       String
  tenantId    String
  reportToken String
  viewerEmail String?
  viewerName  String?
  ipAddress   String?
  userAgent   String?
  viewedAt    DateTime @default(now())

  @@index([jobId])
  @@index([tenantId, viewedAt])
  @@index([reportToken])
}
