# lintPDF marketing site env vars.
#
# Copy to .env.local for local dev:
#   cp packages/web/.env.example packages/web/.env.local

# ─── Required ─────────────────────────────────────────────────────────────
#
# NEXT_PUBLIC_ENABLE_SAAS controls the public marketing posture:
#
#   "true"  → full commercial site: pricing, signup CTAs, blog, integrations,
#              try-it page, sales-y comparison chart, etc.
#   "false" → low-pressure detection-only product info: hero, features,
#              engine page, about, contact, status, compliance only.
#              Everything else builds but is unlinked + noindex +
#              sitemap-excluded + robots-disallowed.
#
# The build will fail loud if this is unset or set to anything else, by
# design — we never want a silent default in either direction.
NEXT_PUBLIC_ENABLE_SAAS=false

# ─── Optional ─────────────────────────────────────────────────────────────
#
# When the OSS engine repo is published, set this to its GitHub URL. The
# /engine page reads it at build time:
#   - empty / unset → renders a "Coming soon" badge with a contact CTA
#   - set to a URL  → renders "View on GitHub" + license + CLI overview
NEXT_PUBLIC_LINTPDF_OSS_REPO_URL=

# Beta-mode banner + waitlist behavior (existing flag).
NEXT_PUBLIC_LINTPDF_BETA_MODE=false

# Engine API URL — used by the /try-it page and the Swagger embed.
NEXT_PUBLIC_LINTPDF_API_URL=https://api.lintpdf.com

# Dashboard URL — used by Header / Footer Sign In / Sign Up CTAs in SaaS mode.
NEXT_PUBLIC_APP_URL=https://app.lintpdf.com
