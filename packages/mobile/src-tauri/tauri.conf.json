{
  "$schema": "https://raw.githubusercontent.com/nicnacnic/tauri-v2-schema/main/tauri.conf.schema.json",
  "productName": "LintPDF",
  "version": "0.1.0",
  "identifier": "com.lintpdf.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "LintPDF",
        "label": "main",
        "width": 480,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "aab"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "13.0"
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "host": "app.lintpdf.com",
          "pathPrefix": ["/view", "/approve"]
        }
      ],
      "desktop": {
        "schemes": ["lintpdf"]
      }
    },
    "dialog": {},
    "notification": {},
    "store": {}
  }
}
