{
  "name": "@thinkneverland/grounded-plugin",
  "version": "0.1.0",
  "description": "Fairy Ring plugin for LintPDF PDF preflight in Pixie Dust dashboard",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./routes": "./dist/routes/index.js"
  },
  "scripts": {
