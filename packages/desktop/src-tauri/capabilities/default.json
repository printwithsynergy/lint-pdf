{
  "$schema": "https://raw.githubusercontent.com/nicnacnic/tauri-v2-schema/main/capability.schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "store:default",
    "updater:default"
  ]
}
