{
  "name": "@lintpdf/database",
  "version": "0.1.0",
  "description": "LintPDF database package with extended tenant structure and preflight engine models",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "require": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "build": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "prisma": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
