#!/bin/bash
set -euo pipefail
export PATH="/opt/homebrew/bin:$PATH"

REPO_ROOT="$(git rev-parse --show-toplevel)"
STAGED=$(git diff --cached --name-only 2>/dev/null || true)
[ -z "$STAGED" ] && exit 0

# ── Detect changed packages (mirrors CI paths-filter) ─────────────────────
CHANGED_ENGINE=false; CHANGED_INFERENCE=false
CHANGED_WEB=false; CHANGED_PLUGIN=false; CHANGED_STRIPE=false; CHANGED_APP=false

while IFS= read -r f; do
  case "$f" in
    packages/engine/*)    CHANGED_ENGINE=true ;;
    packages/inference/*) CHANGED_INFERENCE=true ;;
    packages/web/*)       CHANGED_WEB=true ;;
    packages/plugin/*)    CHANGED_PLUGIN=true ;;
    packages/stripe/*)    CHANGED_STRIPE=true ;;
    packages/app/*)       CHANGED_APP=true ;;
  esac
done <<< "$STAGED"

FAIL=0

# ── Python: Engine — ruff check + ruff format + mypy ──────────────────────
if $CHANGED_ENGINE && [ -d "$REPO_ROOT/packages/engine" ]; then
  echo "🔍 [engine] ruff check..."
  (cd "$REPO_ROOT/packages/engine" && ruff check src/ tests/) || FAIL=1
  echo "🔍 [engine] ruff format --check..."
  (cd "$REPO_ROOT/packages/engine" && ruff format --check src/ tests/) || FAIL=1
  echo "🔍 [engine] mypy..."
  (cd "$REPO_ROOT/packages/engine" && mypy src/) || FAIL=1
fi

# ── Python: Inference — ruff check + ruff format ──────────────────────────
if $CHANGED_INFERENCE && [ -d "$REPO_ROOT/packages/inference" ]; then
  echo "🔍 [inference] ruff check..."
  (cd "$REPO_ROOT/packages/inference" && ruff check src/ tests/) || FAIL=1
  echo "🔍 [inference] ruff format --check..."
  (cd "$REPO_ROOT/packages/inference" && ruff format --check src/ tests/) || FAIL=1
fi

# ── Node packages — typecheck + lint ──────────────────────────────────────
if $CHANGED_WEB || $CHANGED_APP || $CHANGED_PLUGIN || $CHANGED_STRIPE; then
  echo "🔍 [node] typecheck..."
  pnpm typecheck || FAIL=1
  echo "🔍 [node] lint..."
  pnpm lint || FAIL=1
fi

if [ $FAIL -ne 0 ]; then
  echo "❌ Pre-commit checks failed. Fix errors before committing."
  echo "   To skip: git commit --no-verify"
  exit 1
fi
echo "✅ Pre-commit checks passed."
