#!/bin/bash
set -euo pipefail
export PATH="/opt/homebrew/bin:$PATH"

REPO_ROOT="$(git rev-parse --show-toplevel)"
# --diff-filter=ACMR — exclude Deleted files. Otherwise ruff check
# fails on the staged-but-gone path with E902 "No such file or
# directory" and the whole hook bails on a clean cleanup commit.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)
[ -z "$STAGED" ] && exit 0

# ── Collect staged files per package (used for scoped linting below) ──────
ENGINE_FILES=()
INFERENCE_FILES=()
NODE_FILES=()

while IFS= read -r f; do
  case "$f" in
    packages/engine/*.py)       ENGINE_FILES+=("$f") ;;
    packages/inference/*.py)    INFERENCE_FILES+=("$f") ;;
    packages/web/*|packages/plugin/*|packages/stripe/*|packages/app/*)
      [[ "$f" == *.ts || "$f" == *.tsx || "$f" == *.js || "$f" == *.jsx ]] && NODE_FILES+=("$f")
      ;;
  esac
done <<< "$STAGED"

FAIL=0

# ── Python: Engine — scoped ruff check + format on STAGED files only. ─────
# Previous iteration ran ``ruff check src/ tests/`` globally, which meant
# any pre-existing lint debt in an unrelated engine file blocked commits
# in files that were clean on their own. Scope to the staged set so the
# hook only enforces hygiene on what you're actually changing.
# (mypy is intentionally left out — it has strict runtime deps like
# pydantic that aren't installed in the hook sandbox.)
if ((${#ENGINE_FILES[@]})); then
  echo "🔍 [engine] ruff check (${#ENGINE_FILES[@]} staged file(s))..."
  (cd "$REPO_ROOT" && ruff check "${ENGINE_FILES[@]}") || FAIL=1
  echo "🔍 [engine] ruff format --check (${#ENGINE_FILES[@]} staged file(s))..."
  (cd "$REPO_ROOT" && ruff format --check "${ENGINE_FILES[@]}") || FAIL=1
fi

# ── Python: Inference — scoped ruff check + format on STAGED files only. ──
if ((${#INFERENCE_FILES[@]})); then
  echo "🔍 [inference] ruff check (${#INFERENCE_FILES[@]} staged file(s))..."
  (cd "$REPO_ROOT" && ruff check "${INFERENCE_FILES[@]}") || FAIL=1
  echo "🔍 [inference] ruff format --check (${#INFERENCE_FILES[@]} staged file(s))..."
  (cd "$REPO_ROOT" && ruff format --check "${INFERENCE_FILES[@]}") || FAIL=1
fi

# ── Node packages — typecheck + lint are already fast when nothing's
# staged in the relevant package, and the turbo cache keeps re-runs cheap.
# Keep them project-wide because typecheck catches cross-package refs.
if ((${#NODE_FILES[@]})); then
  echo "🔍 [node] typecheck..."
  pnpm typecheck || FAIL=1
  echo "🔍 [node] lint..."
  pnpm lint || FAIL=1
fi

if [ $FAIL -ne 0 ]; then
  echo "❌ Pre-commit checks failed. Fix errors before committing."
  echo "   DO NOT bypass with --no-verify — see CLAUDE.md 'Working"
  echo "   Agreements' for the rationale. Fix the underlying error"
  echo "   in the file(s) you've staged, or unstage the file(s) if"
  echo "   the error is in a hunk you don't own."
  exit 1
fi
echo "✅ Pre-commit checks passed."
