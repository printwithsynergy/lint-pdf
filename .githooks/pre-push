#!/usr/bin/env bash
# Pixie Dust — canonical pre-push hook
# Runs typecheck, lint, and build before allowing a push.
# Install: git config core.hooksPath .githooks

set -euo pipefail

echo "🧚 Pre-push checks..."

echo "→ typecheck"
pnpm typecheck

echo "→ lint"
pnpm lint

echo "→ build"
pnpm build

echo "✅ All pre-push checks passed."
