#!/bin/bash
set -euo pipefail
export PATH="/opt/homebrew/bin:$PATH"

FAIL=0

# ── Python tests ──────────────────────────────────────────────────────────
if [ -d "packages/engine" ] && command -v pytest &>/dev/null; then
  echo "🧪 [engine] pytest..."
  (cd packages/engine && pytest tests/ -v --tb=short -m "not corpus and not integration" -q) || FAIL=1
elif [ -d "packages/engine" ]; then
  echo "⚠️  pytest not installed — skipping engine tests"
fi
if [ -d "packages/inference" ] && command -v pytest &>/dev/null; then
  echo "🧪 [inference] pytest..."
  (cd packages/inference && pytest tests/ -v --tb=short -q) || FAIL=1
elif [ -d "packages/inference" ]; then
  echo "⚠️  pytest not installed — skipping inference tests"
fi

# ── Node tests ────────────────────────────────────────────────────────────
echo "🧪 [node] tests..."
pnpm test || FAIL=1

# ── Semgrep ───────────────────────────────────────────────────────────────
echo "🔍 Running Semgrep..."
if command -v semgrep &>/dev/null; then
  semgrep scan --config auto --severity ERROR --severity WARNING --error packages/ || FAIL=1
else
  echo "⚠️  Semgrep not installed — skipping. Install: brew install semgrep"
fi

# ── E2E Playwright tests (local, no Docker) ──────────────────────────────
# Runs against APP_BASE_URL (defaults to production if not set).
# Set APP_BASE_URL=http://localhost:3001 to test against local dev server.
# External service tests (Stripe) auto-skip when keys aren't set.
# Skips if the target URLs are unreachable (e.g. sandboxed CI environment).
echo "🎭 Running Playwright e2e tests..."
if command -v npx &>/dev/null; then
  APP_URL="${APP_BASE_URL:-https://app.lintpdf.com}"
  WEB_URL="${WEB_BASE_URL:-https://lintpdf.com}"
  APP_REACHABLE=true
  WEB_REACHABLE=true
  curl -sf --max-time 5 "$APP_URL" >/dev/null 2>&1 || APP_REACHABLE=false
  curl -sf --max-time 5 "$WEB_URL" >/dev/null 2>&1 || WEB_REACHABLE=false

  if $APP_REACHABLE; then
    (cd packages/app && npx playwright test --reporter=list) || FAIL=1
  else
    echo "⚠️  App ($APP_URL) unreachable — skipping app e2e tests"
  fi
  if $WEB_REACHABLE; then
    (cd packages/web && npx playwright test --reporter=list) || FAIL=1
  else
    echo "⚠️  Web ($WEB_URL) unreachable — skipping web e2e tests"
  fi
else
  echo "⚠️  npx not available — skipping e2e tests"
fi

if [ $FAIL -ne 0 ]; then
  echo "❌ Pre-push checks failed. Fix errors before pushing."
  echo "   To skip: git push --no-verify"
  exit 1
fi
echo "✅ All pre-push checks passed."
