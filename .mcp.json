{
  "mcpServers": {
    "code-review-graph": {
      "command": "code-review-graph",
      "args": ["serve"],
      "env": {
        "CRG_MAX_IMPACT_DEPTH": "5"
      }
    },
    "ctxo": {
      "command": "npx",
      "args": ["-y", "@ctxo/cli"],
      "env": {}
    },
    "ast-grep": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ],
      "env": {}
    },
    "prisma": {
      "command": "npx",
      "args": ["-y", "prisma", "mcp"],
      "env": {}
    },
    "stripe": {
      "command": "npx",
      "args": ["-y", "@stripe/mcp@latest"],
      "env": {
        "STRIPE_SECRET_KEY": "${env:STRIPE_SECRET_KEY}"
      }
    },
    "railway": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"],
      "env": {}
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "."],
      "env": {}
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "modal": {
      "command": "uv",
      "args": [
        "run",
        "--project", "packages/inference",
        "--extra", "mcp",
        "python", "packages/inference/src/inference_service/mcp_server.py"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--no-sandbox",
        "--ignore-https-errors"
      ]
    },
    "chrome-devtools": {
      "command": "chrome-devtools-mcp",
      "args": [
        "--headless",
        "--isolated",
        "--acceptInsecureCerts",
        "--viewport",
        "1440x900"
      ]
    },
    "openapi-fastapi": {
      "command": "uvx",
      "args": ["awslabs.openapi-mcp-server@latest"],
      "env": {
        "API_SPEC_URL": "http://localhost:8000/openapi.json",
        "API_BASE_URL": "http://localhost:8000",
        "API_NAME": "lintPDF Engine"
      }
    },
    "code-graph-python": {
      "command": "code-graph-mcp",
      "args": [],
      "env": {}
    },
    "pypi-audit": {
      "command": "mcp-pypi",
      "args": [],
      "env": {}
    }
  }
}
