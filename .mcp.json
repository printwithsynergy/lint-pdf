{
  "mcpServers": {
    "modal": {
      "command": "uv",
      "args": [
        "run",
        "--project", "packages/inference",
        "--extra", "mcp",
        "python", "packages/inference/src/inference_service/mcp_server.py"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
