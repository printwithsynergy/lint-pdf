report_*.png

# Stress-harness output — per-run CSV/MD artifacts are local to the
# machine that ran scripts/stress_preflight_folder.py. The committed
# preflight-stress-results.md / -smoke.md / -smoke-metrics.csv capture
# the canonical tier-1 findings; everything else from subsequent
# tier-1 reruns, tier-2 sweeps, PgBouncer smokes, retry probes, etc.
# is ignored. Mirrors PR #142 on main.
preflight-stress-*-metrics.csv
preflight-stress-*-results.md
preflight-stress-results-*.md
preflight-stress-tier*.csv
preflight-stress-tier*.md
preflight-stress-rerun-*.csv
preflight-stress-rerun-*.md
preflight-stress-1file-*.csv
preflight-stress-1file-*.md
preflight-stress-pgbouncer-*.csv
preflight-stress-pgbouncer-*.md

# Local engine storage (runtime data from seed_and_serve.py)
.local-storage/

# ctxo MCP index (local per-machine symbol cache; rebuilt on demand)
.ctxo/

# Stripe setup script output — environment-specific product/price IDs.
# Runtime code keys off `lookup_key` (checked into source), so this file
# is for local debugging only.
packages/stripe/scripts/.stripe-ids.json

# Stress-test runtime artifacts generated by scripts/stress_preflight_folder.py.
# The committed `preflight-stress-smoke.md` + `preflight-stress-smoke-metrics.csv`
# in PR #110 are a historical incident snapshot; any future run writes fresh
# per-run artifacts that aren't worth versioning.
preflight-stress-results-*.md
preflight-stress-rerun-metrics.csv
preflight-stress-tier*-*.md
preflight-stress-tier*-*.csv
# Generic catch-all for any ad-hoc stress-harness run (e.g. the
# pgbouncer-smoke, step-6 benches, etc.) so we don't accumulate
# untracked files after every QA.
preflight-stress-*-metrics.csv
preflight-stress-*-results.md
