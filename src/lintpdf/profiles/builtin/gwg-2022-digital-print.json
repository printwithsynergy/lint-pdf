{
  "name": "GWG 2022 Digital Print (Variant 8)",
  "description": "GWG 2022 process control for digital printing. Accepts CMYK and RGB workflows.",
  "version": "1.0",
  "conformance": null,
  "workflow": "auto",
  "checks": {
    "enabled": [
      "LPDF_*"
    ],
    "disabled": [
      "PDFX4-*",
      "LPDF_FONT_016",
      "LPDF_FONT_017"
    ],
    "severity_overrides": {}
  },
  "thresholds": {
    "min_dpi": 200.0,
    "max_dpi": 600.0,
    "tac_limit": 300.0,
    "min_bleed_mm": 3.0,
    "hairline_threshold": 0.25,
    "small_text_threshold": 6.0,
    "very_small_text_threshold": 4.0,
    "safety_margin_mm": 3.0,
    "max_file_size_mb": 500.0,
    "min_pdf_version": "1.6"
  }
}
