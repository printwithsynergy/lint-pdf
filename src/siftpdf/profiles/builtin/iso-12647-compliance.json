{
  "name": "ISO 12647 Compliance",
  "description": "ISO 12647 compliance checking with G7 and GRACoL readiness.",
  "version": "1.0",
  "conformance": "pdfx4",
  "workflow": "CMYK",
  "checks": {
    "enabled": [
      "LPDF_*",
      "PDFX4-*"
    ],
    "disabled": [
      "LPDF_FONT_016",
      "LPDF_FONT_017"
    ],
    "severity_overrides": {}
  },
  "thresholds": {
    "min_dpi": 250.0,
    "max_dpi": 600.0,
    "tac_limit": 330.0,
    "target_output_condition": "fogra39_coated",
    "gamut_check": true,
    "min_pdf_version": "1.4"
  }
}
